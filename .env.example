# Copy to .env and fill in. NEVER commit .env (it is git-ignored).

# Enable Banking (SPEC §6, Phase 0) — personal/own-data application.
ENABLE_BANKING_APP_ID=
# Absolute path to the app private key, stored OUTSIDE this repo. Path only —
# the key itself is never copied into the repo or the database.
ENABLE_BANKING_PRIVATE_KEY_PATH=

# Telegram bot (SPEC §7) — created via @BotFather. TELEGRAM_CHAT_ID is where
# pushes are DELIVERED (your own chat, or a group's negative id).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional. The user id AUTHORIZED to issue commands and taps (from.id). Defaults
# to TELEGRAM_CHAT_ID — correct for a 1:1 chat, where sender == chat. Set it only
# when delivering into a GROUP (whose chat id is not your user id), so the bot can
# post to the group while only you drive it.
TELEGRAM_OWNER_ID=
