#!/bin/sh
# Sync git-ignored owner config (sentinel/rules.local.yaml, sentinel/bills.local.yaml)
# to the GitHub Actions repo secrets that CD materializes onto the prod host
# (RULES_LOCAL_YAML / BILLS_LOCAL_YAML — see deploy.yml and docs/DEPLOY.md).
#
# Installed as the pre-push hook (make hooks), so a push can never trigger a
# deploy that ships stale owner config; also runnable by hand: make secrets.
# A content hash per secret is cached under .git/ so unchanged files cost no
# API call. Failures WARN loudly but never block the push — the deploy would
# then reuse the previous secret, which is exactly what happens today without
# this script.
set -eu

root=$(git rev-parse --show-toplevel)
state_dir="$(git -C "$root" rev-parse --git-dir)/sentinel"
mkdir -p "$state_dir"

hash_file() {
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$1" | cut -d' ' -f1
  else
    shasum -a 256 "$1" | cut -d' ' -f1
  fi
}

synced=0

sync_one() { # $1 = repo-relative file, $2 = secret name
  file="$root/$1"
  [ -f "$file" ] || return 0
  new_hash=$(hash_file "$file")
  state_file="$state_dir/secret-$2.sha256"
  if [ -f "$state_file" ] && [ "$(cat "$state_file")" = "$new_hash" ]; then
    return 0 # unchanged since the last successful sync
  fi
  if ! command -v gh >/dev/null 2>&1; then
    echo "WARNING: gh CLI not installed — $2 NOT synced; the next deploy ships the PREVIOUS $1" >&2
    return 0
  fi
  if gh secret set "$2" <"$file"; then
    printf '%s' "$new_hash" >"$state_file"
    echo "synced: $1 -> repo secret $2"
    synced=1
  else
    echo "WARNING: 'gh secret set $2' failed (not authenticated?) — the next deploy ships the PREVIOUS $1" >&2
  fi
}

sync_one sentinel/rules.local.yaml RULES_LOCAL_YAML
sync_one sentinel/bills.local.yaml BILLS_LOCAL_YAML

if [ "$synced" = 1 ]; then
  echo "note: secrets land on prod at the NEXT deploy. Config-only change (no push coming)?"
  echo "      Trigger one now:  gh workflow run Deploy --ref main"
fi
